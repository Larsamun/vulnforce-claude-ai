<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>VulnForge AI Report — {{ desc.application_name }}</title>
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    if (window.mermaid) { mermaid.initialize({ startOnLoad: true, securityLevel: "strict", theme: "neutral" }); }
  });
</script>
<style>
  :root { --bg:#0f172a; --panel:#fff; --ink:#1e293b; --muted:#64748b; --line:#e2e8f0; }
  * { box-sizing: border-box; }
  body { margin:0; font-family: -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
         color:var(--ink); background:#f1f5f9; line-height:1.5; }
  header { background:var(--bg); color:#fff; padding:28px 40px; }
  header h1 { margin:0 0 4px; font-size:22px; }
  header .sub { color:#94a3b8; font-size:13px; }
  main { max-width: 1040px; margin: 0 auto; padding: 24px 24px 80px; }
  section { background:var(--panel); border:1px solid var(--line); border-radius:10px;
            padding:22px 26px; margin:18px 0; }
  h2 { font-size:17px; margin:0 0 14px; border-bottom:2px solid var(--line); padding-bottom:8px; }
  h3 { font-size:14px; margin:18px 0 6px; }
  .muted { color:var(--muted); }
  .pill { display:inline-block; padding:2px 9px; border-radius:999px; color:#fff;
          font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.03em; }
  .counts { display:flex; gap:10px; flex-wrap:wrap; margin:6px 0 0; }
  .count { border-radius:8px; padding:10px 14px; color:#fff; min-width:84px; text-align:center; }
  .count b { display:block; font-size:22px; }
  table { width:100%; border-collapse: collapse; font-size:13px; }
  th, td { text-align:left; padding:8px 10px; border-bottom:1px solid var(--line); vertical-align: top; }
  th { color:var(--muted); font-weight:600; }
  code { background:#f1f5f9; padding:1px 5px; border-radius:4px; font-size:12px; }
  .finding { border:1px solid var(--line); border-radius:8px; margin:12px 0; padding:14px 16px; }
  .finding .meta { font-size:12px; color:var(--muted); margin:4px 0 8px; }
  .grid2 { display:grid; grid-template-columns: 1fr 1fr; gap:18px; }
  @media (max-width: 820px){ .grid2 { grid-template-columns: 1fr; } }
  .mermaid { background:#f8fafc; border:1px solid var(--line); border-radius:8px; padding:10px; overflow:auto; }
  .tag { font-size:11px; background:#eef2ff; color:#3730a3; border-radius:6px; padding:1px 7px; margin-right:4px; }
  details summary { cursor:pointer; font-weight:600; }
  .ai-note { font-size:12px; }
</style>
</head>
<body>
<header>
  <h1>VulnForge AI — Security Report</h1>
  <div class="sub">{{ desc.application_name }} &middot; environment: {{ desc.environment }}
     &middot; scan mode: {{ config.scan_mode.value }} &middot; generated {{ generated_at }}
     &middot; v{{ version }}</div>
</header>
<main>

  <!-- EXECUTIVE -->
  <section>
    <h2>Executive summary</h2>
    <p>{{ app_summary }}</p>
    <p>{{ exec_summary }}</p>
    <div class="counts">
      {% for sev, n in counts.items() %}
      <div class="count" style="background: {{ sev|sevcolor }}"><b>{{ n }}</b>{{ sev }}</div>
      {% endfor %}
    </div>
    <p class="ai-note muted" style="margin-top:14px">
      AI enrichment: {% if ai_enabled %}enabled ({{ ai_provider }}){% else %}disabled — deterministic summaries shown. Enable via VULNFORGE_AI_PROVIDER.{% endif %}
    </p>
  </section>

  <!-- CONTEXT + ARCHITECTURE -->
  <section>
    <h2>Application context &amp; architecture</h2>
    <table>
      <tr><th>Business purpose</th><td>{{ desc.business_purpose or "—" }}</td></tr>
      <tr><th>Primary users</th><td>{{ desc.primary_users|join(", ") or "—" }}</td></tr>
      <tr><th>Data criticality</th><td>{{ desc.data_criticality }}</td></tr>
      <tr><th>Sensitive data</th><td>{{ desc.sensitive_data|join(", ") or "—" }}</td></tr>
      <tr><th>Critical flows</th><td>{{ desc.critical_flows|join(", ") or "—" }}</td></tr>
      <tr><th>Testing goals</th><td>{{ desc.testing_goals|join(", ") or "—" }}</td></tr>
      <tr><th>Detected stack</th><td>{% for s in stack %}<span class="tag">{{ s }}</span>{% else %}—{% endfor %}</td></tr>
    </table>
    <div class="grid2" style="margin-top:16px">
      <div><h3>Architecture (inferred)</h3><div class="mermaid">{{ arch_diagram }}</div></div>
      <div><h3>Trust boundaries</h3><div class="mermaid">{{ trust_diagram }}</div></div>
    </div>
  </section>

  <!-- SCAN COVERAGE -->
  <section>
    <h2>Scan coverage</h2>
    <p class="muted">Each scanner runs if available (native or Docker) and is skipped gracefully otherwise.</p>
    <table>
      <thead><tr><th>Scanner</th><th>Result</th><th>Findings</th><th>Detail</th></tr></thead>
      <tbody>
        {% for s in stages %}
        <tr>
          <td><code>{{ s.name }}</code></td>
          <td>{% if s.state == "ran" %}✅ ran{% elif s.state == "skipped" %}⏭️ skipped{% else %}⚠️ {{ s.state }}{% endif %}</td>
          <td>{{ s.findings }}</td>
          <td class="muted">{{ s.detail }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  <!-- FINDINGS -->
  <section>
    <h2>Findings ({{ findings|length }})</h2>
    {% if not findings %}
      <p class="muted">No findings recorded. If scanners were skipped, install the tools or enable Docker and re-run.</p>
    {% endif %}
    {% for f in findings %}
    <div class="finding">
      <span class="pill" style="background: {{ f.severity.value|sevcolor }}">{{ f.severity.value }}</span>
      <strong>{{ f.title }}</strong>
      <div class="meta">
        {{ f.source }} &middot; {{ f.engine.value }} &middot; {{ f.category }} &middot; confidence: {{ f.confidence.value }}
        {% if f.file %}&middot; <code>{{ f.file }}{% if f.line %}:{{ f.line }}{% endif %}</code>{% endif %}
        {% if f.endpoint %}&middot; <code>{{ f.method or "" }} {{ f.endpoint }}</code>{% endif %}
        {% if f.rule_id %}&middot; rule <code>{{ f.rule_id }}</code>{% endif %}
      </div>
      {% if f.description %}<div>{{ f.description }}</div>{% endif %}
      {% if f.evidence %}<div style="margin-top:6px"><span class="muted">Evidence:</span> <code>{{ f.evidence }}</code></div>{% endif %}
      {% if f.remediation %}<div style="margin-top:6px"><span class="muted">Fix:</span> {{ f.remediation }}</div>{% endif %}
      {% if f.suggested_dast_tests %}<div style="margin-top:6px"><span class="muted">DAST follow-up:</span> {{ f.suggested_dast_tests|join("; ") }}</div>{% endif %}
      {% if f.cwe or f.owasp %}<div class="meta" style="margin-top:6px">{% for c in f.cwe %}<span class="tag">{{ c }}</span>{% endfor %}{% if f.owasp %}<span class="tag">{{ f.owasp }}</span>{% endif %}</div>{% endif %}
    </div>
    {% endfor %}
  </section>

  <!-- ATTACK PATHS -->
  {% if finding_diagrams %}
  <section>
    <h2>Attack paths &amp; data flows (high / critical)</h2>
    {% for d in finding_diagrams %}
    <details {% if loop.first %}open{% endif %}>
      <summary>{{ d.title }} <span class="muted">({{ d.severity }})</span></summary>
      <div class="grid2" style="margin-top:10px">
        <div><h3>Attack path</h3><div class="mermaid">{{ d.attack_path }}</div></div>
        <div><h3>Data flow</h3><div class="mermaid">{{ d.dataflow }}</div></div>
      </div>
    </details>
    {% endfor %}
  </section>
  {% endif %}

  <p class="muted" style="text-align:center; font-size:12px">
    Generated by VulnForge AI v{{ version }} — orchestrated scanners, normalized findings, AI-assisted reporting.
  </p>
</main>
</body>
</html>
