# VulnForge AI configuration. Copy to .env and fill in as needed.
# Everything here is OPTIONAL. With no AI provider configured, VulnForge still
# runs SAST/DAST and produces reports using deterministic (non-AI) summaries.

# --- AI provider ---------------------------------------------------------
# One of: none | anthropic | openai
VULNFORGE_AI_PROVIDER=none

# Anthropic (recommended). Requires:  pip install "vulnforge[anthropic]"
ANTHROPIC_API_KEY=
VULNFORGE_ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI. Requires:  pip install "vulnforge[openai]"
OPENAI_API_KEY=
VULNFORGE_OPENAI_MODEL=gpt-4o

# --- Tooling -------------------------------------------------------------
# How scanners run: auto (prefer docker, fall back to native) | docker | native
VULNFORGE_RUNNER=auto
# Per-tool timeout in seconds.
VULNFORGE_TOOL_TIMEOUT=900
